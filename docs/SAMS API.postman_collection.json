    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const cookie = pm.response.headers.get('Set-Cookie');\r",
              "if (cookie) {\r",
              "  pm.environment.set('session_cookie', cookie);\r",
              "  console.log('Session cookie saved');\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n\t\"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/sign-in/email",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "sign-in",
            "email"
          ]
        }
      },
      "response": []
    },
